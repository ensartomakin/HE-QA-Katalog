# PostgreSQL (Railway'de otomatik sağlanır)
DATABASE_URL=postgresql://user:password@localhost:5432/heqa

# tsoft kimlik bilgilerini şifrelemek için (Ayarlar ekranından girilen apiPass/apiToken)
ENCRYPTION_KEY=change-me-to-a-long-random-string

# apps/web ile bu servis arasındaki paylaşılan gizli anahtar
INTERNAL_API_KEY=change-me-to-a-long-random-string

PORT=3001
NODE_ENV=development
LOG_LEVEL=info
