# Railway'de barındırılan worker servisinin adresi
WORKER_URL=http://localhost:3001

# apps/worker ile paylaşılan gizli anahtar (apps/worker/.env.example'daki ile aynı olmalı)
INTERNAL_API_KEY=change-me-to-a-long-random-string

# Admin oturum token'larını doğrulamak için — apps/worker/.env.example'daki JWT_SECRET ile AYNI olmalı
JWT_SECRET=change-me-to-a-long-random-string
